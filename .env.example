# Slack Bot - get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic - get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key

# Anthropic Admin key - only needed to run create_api_key.py
# Get this from https://console.anthropic.com/settings/admin-keys
ANTHROPIC_ADMIN_KEY=sk-ant-admin-your-admin-key

# Claude model - defaults to claude-sonnet-4-20250514
# CLAUDE_MODEL=claude-sonnet-4-20250514
