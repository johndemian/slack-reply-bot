# Slack Bot - get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic - get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key

# X/Twitter API - get this from https://developer.x.com/en/portal
# Optional: only needed if you want to analyze X.com posts
X_BEARER_TOKEN=your-x-bearer-token

# Claude model - defaults to claude-sonnet-4-20250514
# CLAUDE_MODEL=claude-sonnet-4-20250514
